rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: conversions
    // Document ID: auto-generated
    // Fields:
    //   - input: string (required)
    //   - output: string (required)
    //   - format: string (required)
    //   - timestamp: timestamp (required)
    //   - userId: string (required)
    //
    // Collection: template_extractions
    // Document ID: auto-generated
    // Fields:
    //   - rawText: string (required)
    //   - name: string (optional)
    //   - phone: string (optional)
    //   - email: string (optional)
    //   - taxInfo: string (optional)
    //   - address: string (optional)
    //   - timestamp: timestamp (required)
    //   - userId: string (required)
    //
    // Collection: custom_conversion_templates
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required)
    //   - operations: list (required)
    //   - timestamp: timestamp (required)
    //   - userId: string (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function uidUnchanged() {
      return !('userId' in request.resource.data) || request.resource.data.userId == request.auth.uid;
    }

    function uidNotModified() {
      return !('userId' in request.resource.data) || request.resource.data.userId == resource.data.userId;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidConversion(data) {
      return hasOnlyAllowedFields(['input', 'output', 'format', 'timestamp', 'userId']) &&
             data.input is string && data.input.size() <= 100000 &&
             data.output is string && data.output.size() <= 100000 &&
             data.format is string && data.format.size() <= 100 &&
             data.timestamp is timestamp &&
             data.userId is string && data.userId.size() > 0;
    }

    function isValidTemplateExtraction(data) {
      return hasOnlyAllowedFields(['rawText', 'name', 'phone', 'email', 'taxInfo', 'address', 'timestamp', 'userId']) &&
             data.rawText is string && data.rawText.size() <= 100000 &&
             (!('name' in data) || (data.name is string && data.name.size() <= 1000)) &&
             (!('phone' in data) || (data.phone is string && data.phone.size() <= 100)) &&
             (!('email' in data) || (data.email is string && data.email.size() <= 200)) &&
             (!('taxInfo' in data) || (data.taxInfo is string && data.taxInfo.size() <= 200)) &&
             (!('address' in data) || (data.address is string && data.address.size() <= 5000)) &&
             data.timestamp is timestamp &&
             data.userId is string && data.userId.size() > 0;
    }

    function isValidCustomTemplate(data) {
      return hasOnlyAllowedFields(['name', 'operations', 'timestamp', 'userId']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.operations is list && data.operations.size() <= 50 &&
             data.timestamp is timestamp &&
             data.userId is string && data.userId.size() > 0;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /conversions/{docId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && 
                    hasRequiredFields(['input', 'output', 'format', 'timestamp', 'userId']) &&
                    isValidConversion(request.resource.data) && 
                    uidUnchanged();
      allow update: if isDocOwner() && 
                    hasRequiredFields(['input', 'output', 'format', 'timestamp', 'userId']) &&
                    isValidConversion(request.resource.data) && 
                    uidNotModified();
      allow delete: if isDocOwner();
    }

    match /template_extractions/{docId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && 
                    hasRequiredFields(['rawText', 'timestamp', 'userId']) &&
                    isValidTemplateExtraction(request.resource.data) && 
                    uidUnchanged();
      allow update: if isDocOwner() && 
                    hasRequiredFields(['rawText', 'timestamp', 'userId']) &&
                    isValidTemplateExtraction(request.resource.data) && 
                    uidNotModified();
      allow delete: if isDocOwner();
    }

    match /custom_conversion_templates/{docId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && 
                    hasRequiredFields(['name', 'operations', 'timestamp', 'userId']) &&
                    isValidCustomTemplate(request.resource.data) && 
                    uidUnchanged();
      allow update: if isDocOwner() && 
                    hasRequiredFields(['name', 'operations', 'timestamp', 'userId']) &&
                    isValidCustomTemplate(request.resource.data) && 
                    uidNotModified();
      allow delete: if isDocOwner();
    }
  }
}
